{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bolly Docs",
  "colors": {
    "primary": "#c9a45c",
    "light": "#d4b87a",
    "dark": "#c9a45c"
  },
  "favicon": "/favicon.svg",
  "modeToggle": {
    "default": "dark"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "quickstart"
            ]
          },
          {
            "group": "Installation",
            "pages": [
              "installation/overview",
              "installation/quick-install",
              "installation/docker",
              "installation/desktop-app",
              "installation/from-source"
            ]
          },
          {
            "group": "Configuration",
            "pages": [
              "installation/configuration",
              "installation/api-keys"
            ]
          },
          {
            "group": "Help",
            "pages": [
              "installation/troubleshooting"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "pages": [
              "api-reference/endpoint/get",
              "api-reference/endpoint/create",
              "api-reference/endpoint/delete",
              "api-reference/endpoint/webhook"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub",
          "href": "https://github.com/triangle-int/bolly",
          "icon": "github"
        },
        {
          "anchor": "Community",
          "href": "https://discord.gg/bolly",
          "icon": "discord"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Website",
        "href": "https://bollyai.dev"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Bolly",
      "href": "https://bollyai.dev"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/bollyai",
      "github": "https://github.com/triangle-int/bolly",
      "discord": "https://discord.gg/bolly"
    }
  }
}